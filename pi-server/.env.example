# Copy to .env and fill in values (or set in docker-compose.yml environment section)

# Flask
FLASK_SECRET_KEY=change-me-to-a-random-string

# Google Photos OAuth — create at https://console.cloud.google.com/
# Enable "Photos Library API", create OAuth 2.0 Web client credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5001/google/callback

# Optional tuning
# DITHER_METHOD=floyd_steinberg
# PROCESSING_INTERVAL_SECONDS=86400
