# Copy to pi-server/.env and fill in values (docker compose loads this file)
#
# Minimum for local-only use (gallery upload, no Google):
#   FLASK_SECRET_KEY=<long random string>
#
# Google vars can stay empty — the gallery works without them.

# Required for session signing (uploads and optional OAuth)
FLASK_SECRET_KEY=change-me-to-a-long-random-string

# --- Optional: Google Photos import (/google) ---
# Skip this block if you only upload photos through the gallery.
#
# https://console.cloud.google.com/
# 1. Enable "Photos Picker API"
# 2. OAuth consent screen → External → add yourself as Test user
# 3. Credentials → OAuth client ID → Web application
# 4. Redirect URI must match how you open the app:
#    Mac dev:  http://localhost:5001/google/callback
#    Pi / LAN: http://192.168.x.x.sslip.io:5001/google/callback
#    (Google rejects bare IPs like http://192.168.1.42:5001/...)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5001/google/callback
# GOOGLE_REDIRECT_URI=http://192.168.50.202.sslip.io:5001/google/callback

# Auto-set in code when REDIRECT_URI uses http:// — only if you override manually:
# OAUTHLIB_INSECURE_TRANSPORT=1

# --- Optional processing defaults ---
# DITHER_METHOD=floyd_steinberg
# BINARY_PACK_MODE=byte
# FRAME_WIDTH=800
# FRAME_HEIGHT=480
