# Copy to pi-server/.env and fill in values (docker compose loads this file)

# Required for OAuth session signing — use a long random string, never change after connecting
FLASK_SECRET_KEY=change-me-to-a-random-string

# Google Photos OAuth — https://console.cloud.google.com/
# 1. Enable "Photos Picker API" (Library API no longer lists your full library)
# 2. OAuth consent screen → External → add yourself as Test user
# 3. Credentials → OAuth client ID → Web application
# 4. Redirect URI — pick one and match it exactly in Google Cloud + how you open the app:
#    Mac dev:  http://localhost:5001/google/callback
#    Pi / LAN: http://192.168.x.x.sslip.io:5001/google/callback
#    (replace 192.168.x.x with your Pi's LAN IP — sslip.io resolves that hostname to the IP)
#    Google rejects raw IPs like http://192.168.1.42:5001/... but accepts sslip.io hostnames.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5001/google/callback
# GOOGLE_REDIRECT_URI=http://192.168.50.202.sslip.io:5001/google/callback

# Auto-set in code when REDIRECT_URI uses http:// — only needed if you override manually:
# OAUTHLIB_INSECURE_TRANSPORT=1
# DITHER_METHOD=floyd_steinberg
